  "description": "Use goose with your Claude Code subscription via the claude-agent-acp adapter.",
  "doc_url": "https://github.com/zed-industries/claude-agent-acp",
  "binary": "claude-agent-acp",
  "env_remove": ["CLAUDECODE"],
  "allow_option_id": "allow",
  "reject_option_id": "reject",
